# Copy to .env and fill in (do not commit .env).
# mattermost-tui loads .env by searching upward from the directory you run the command in.

# Required: server base URL (no /api/v4 suffix)
MATTERMOST_URL=https://chat.example.com

# Use either a personal access token OR login + password (not both required in file).

# Personal access token (Account Settings → Security → Personal Access Tokens)
# MATTERMOST_TOKEN=

# Password login (if MATTERMOST_TOKEN is unset)
# MATTERMOST_LOGIN=you@example.com
# (alias: MATTERMOST_USERNAME)
# MATTERMOST_PASSWORD=   # never pass password on the CLI; only env, .env, or prompt
#
# Optional: proxy for API (overrides HTTP_PROXY / HTTPS_PROXY / ALL_PROXY for this app when set)
# MATTERMOST_PROXY=http://proxy.example.com:8080
# MATTERMOST_PROXY=socks5://127.0.0.1:1080
#
# Values in .env override the same variables already set in your shell when a .env file is found.
